# Application
APP_NAME="Finance Tracker API"
APP_VERSION="1.1.0"
HOST="127.0.0.1"
PORT=8000

# Database
DATABASE_URL="sqlite:///./finance_tracker.db"

# Security (Change in production!)
SECRET_KEY="finance-tracker-secret-key-change-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Pagination
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100
